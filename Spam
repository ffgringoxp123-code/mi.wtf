local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- 1. Создание GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 130, 0, 55)
frame.Position = UDim2.new(0.5, -65, 0.5, -27)
frame.BackgroundColor3 = Color3.new(0, 0, 0)
frame.BorderSizePixel = 0 -- Убираем стандартную рамку, заменим её своими бортиками
frame.Active = true

-- Функция для создания бортиков
local function createBorder(name, size, pos)
    local b = Instance.new("Frame", frame)
    b.Name = name
    b.Size = size
    b.Position = pos
    b.BackgroundColor3 = Color3.new(1, 1, 1) -- Белые полоски
    b.BorderSizePixel = 0
    b.ZIndex = 10 -- Чтобы они были поверх кнопки
    return b
end

-- Создаем 4 бортика по периметру
local borders = {
    createBorder("Top", UDim2.new(1, 0, 0, 3), UDim2.new(0, 0, 0, 0)),
    createBorder("Bottom", UDim2.new(1, 0, 0, 3), UDim2.new(0, 0, 1, -3)),
    createBorder("Left", UDim2.new(0, 3, 1, 0), UDim2.new(0, 0, 0, 0)),
    createBorder("Right", UDim2.new(0, 3, 1, 0), UDim2.new(1, -3, 0, 0))
}

-- Скрипт перетаскивания (привязан только к бортикам)
local dragging, dragInput, dragStart, startPos

local function initDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end

-- Подключаем перетаскивание к каждому бортику
for _, border in pairs(borders) do
    border.InputBegan:Connect(initDrag)
end

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Кнопка (теперь она не мешает таскать за края)
local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(1, -6, 1, -6)
button.Position = UDim2.new(0, 3, 0, 3)
button.BackgroundTransparency = 1
button.Text = "START"
button.TextColor3 = Color3.new(1, 1, 1)
button.Font = Enum.Font.SourceSansBold
button.TextSize = 20
button.ZIndex = 5

-- 2. Логика спама (Оригинальная)
local activated = false
local remote = nil
local f_raw = nil
local c = {nil, nil, nil, nil, nil, nil, nil}

local function setupCapture()
    local mt = getrawmetatable(game)
    local old = mt.__index
    setreadonly(mt, false)
    mt.__index = function(self, key)
        if (key == "FireServer" or key == "InvokeServer") then
            return function(_, ...)
                local a = {...}
                if #a == 7 and typeof(a[4]) == "CFrame" then
                    remote, f_raw = self, self.FireServer
                    c[1], c[2], c[3], c[4], c[5], c[6], c[7] = a[1], a[2], a[3], a[4], a[5], a[6], a[7]
                    if not activated then 
                        button.Text = "READY"
                        button.TextColor3 = Color3.new(0, 1, 0) 
                    end
                end
                return old(self, key)(self, ...)
            end
        end
        return old(self, key)
    end
    setreadonly(mt, true)
end

RunService.Heartbeat:Connect(function()
    if activated and remote and f_raw then
        f_raw(remote, c[1], c[2], c[3], c[4], c[5], c[6], c[7])
        f_raw(remote, c[1], c[2], c[3], c[4], c[5], c[6], c[7])
        f_raw(remote, c[1], c[2], c[3], c[4], c[5], c[6], c[7])
        f_raw(remote, c[1], c[2], c[3], c[4], c[5], c[6], c[7])
    end
end)

local function toggle()
    if not remote then return end
    activated = not activated
    button.Text = activated and "STOP" or "START"
    button.TextColor3 = activated and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
end

button.MouseButton1Click:Connect(toggle)
UserInputService.InputBegan:Connect(function(i, p)
    if not p and i.KeyCode == Enum.KeyCode.F then toggle() end
end)

setupCapture()
