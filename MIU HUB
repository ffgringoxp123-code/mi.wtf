-- === HÀM CẬP NHẬT DANH SÁCH MUA ===
local function updatePurchaseList()
    -- Xóa list cũ
    for _, child in ipairs(PurchaseList:GetChildren()) do
        if child ~= ListTitle then
            child:Destroy()
        end
    end
    
    -- Thêm items mới
    local yOffset = 25
    PurchaseList.CanvasSize = UDim2.new(0, 0, 0, math.max(80, #purchasedItems * 25 + 30))
    
    for _, item in ipairs(purchasedItems) do
        local itemLabel = Instance.new("TextLabel")
        itemLabel.Size = UDim2.new(1, -10, 0, 20)
        itemLabel.Position = UDim2.new(0, 5, 0, yOffset)
        itemLabel.BackgroundTransparency = 1
        itemLabel.Text = item.name .. " (-" .. tostring(item.price) .. " Robux)"
        itemLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
        itemLabel.TextScaled = true
        itemLabel.Font = Enum.Font.Gotham
        itemLabel.TextXAlignment = Enum.TextXAlignment.Left
        itemLabel.Parent = PurchaseList
        yOffset = yOffset + 25
    end
end

