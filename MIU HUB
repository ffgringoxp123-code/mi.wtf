-- === TÌM CÁC PHẦN TỬ ROBUX TRONG GAME ===
local function findRobuxLabels()
    local labels = {}
    local function search(obj)
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local text = obj.Text or ""
            -- Tìm label có chứa số Robux (thường có ký hiệu R$ hoặc ₳)
            if text:find("R$") or text:find("₳") or text:find("Robux") or text:match("^%d+$") then
                table.insert(labels, obj)
            end
        end
        for _, child in ipairs(obj:GetChildren()) do
            search(child)
        end
    end
    search(game:GetService("CoreGui"))
    search(game:GetService("Players").LocalPlayer.PlayerGui)
    search(game:GetService("Players").LocalPlayer:FindFirstChild("PlayerScripts"))
    return labels
end

-- === CẬP NHẬT ROBUX GIẢ TRÊN GIAO DIỆN ===
local function updateFakeRobuxDisplay()
    local labels = findRobuxLabels()
    for _, label in ipairs(labels) do
        if label.Text:find("R$") then
            label.Text = "R$ " .. tostring(fakeRobuxAmount)
        elseif label.Text:find("₳") then
            label.Text = "₳ " .. tostring(fakeRobuxAmount)
        elseif tonumber(label.Text) then
            label.Text = tostring(fakeRobuxAmount)
        end
    end
end

-- === THEO DÕI CÁC NÚT MUA ĐỒ ===
local function hookPurchaseButtons()
    local function searchButtons(obj)
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            local text = (obj.Text or ""):lower()
            local name = (obj.Name or ""):lower()
            
            -- Tìm nút có liên quan đến mua hàng
            if text:find("buy") or text:find("mua") or text:find("purchase") or text:find("get") or
               name:find("buy") or name:find("purchase") or name:find("shop") or name:find("mua") or
               text:find("equip") or text:find("trang bị") or text:find("s%d+") then
                
                -- Lưu kết nối cũ
                local oldClick = obj.MouseButton1Click
                
                -- Thay thế bằng kết nối mới
                obj.MouseButton1Click:Connect(function()
                    if isModActive then
                        -- Fake mua hàng
                        local itemName = "Item"
                        -- Tìm tên item từ label gần đó
                        local parent = obj.Parent
                        if parent then
                            for _, child in ipairs(parent:GetChildren()) do
                                if child:IsA("TextLabel") and child ~= obj then
                                    itemName = child.Text
                                    break
                                end
                            end
                        end
                        
                        -- Tính giá từ label
                        local price = 0
                        for _, child in ipairs(obj.Parent:GetChildren()) do
                            if child:IsA("TextLabel") then
                                local num = tonumber(child.Text:match("%d+"))
                                if num then
                                    price = num
                                    break
                                end
                            end
                        end
                        
                        if price > 0 and fakeRobuxAmount >= price then
                            fakeRobuxAmount = fakeRobuxAmount - price
                            table.insert(purchasedItems, {name = itemName, price = price})
                            updateFakeRobuxDisplay()
                            
                            -- Hiển thị thông báo
                            local notify = Instance.new("Message")
                            notify.Text = "✅ Đã mua '" .. itemName .. "' thành công! (-" .. price .. " Robux ảo)"
                            notify.Parent = game:GetService("Players").LocalPlayer.PlayerGui
                            game:GetService("Debris"):AddItem(notify, 3)
                        else
                            local notify = Instance.new("Message")
                            notify.Text = "❌ Không đủ Robux ảo! Cần " .. tostring(price) .. " Robux"
                            notify.Parent = game:GetService("Players").LocalPlayer.PlayerGui
                            game:GetService("Debris"):AddItem(notify, 3)
                        end
                    end
                end)
            end
        end
        for _, child in ipairs(obj:GetChildren()) do
            searchButtons(child)
        end
    end
    searchButtons(game:GetService("CoreGui"))
    searchButtons(game:GetService("Players").LocalPlayer.PlayerGui)
end

