            color: #666;
            font-size: 12px;
            letter-spacing: 0.5px;
        }
        .fr-credit span {
            color: #ff00ea;
            font-weight: 700;
            background: linear-gradient(90deg, #ff00ea, #00d4ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        /* Notification */
        .fr-notification {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000000;
            padding: 14px 24px;
            border-radius: 12px;
            color: #fff;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            max-width: 350px;
        }
        .fr-notification.show {
            transform: translateX(0);
        }
        .fr-notification.success {
            background: linear-gradient(135deg, #00e676, #00c853);
        }
        .fr-notification.error {
            background: linear-gradient(135deg, #ff1744, #d50000);
        }
        .fr-notification.info {
            background: linear-gradient(135deg, #00d4ff, #0080ff);
        }
        /* Arrow when minimized */
        .fr-arrow-icon {
            font-size: 24px;
            color: #00d4ff;
            text-shadow: 0 0 10px rgba(0,212,255,0.8);
            animation: frPulse 2s infinite;
        }
        @keyframes frPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        /* Drag handle */
        .fr-drag-handle {
            cursor: move;
        }
    `);

    // ===================== NOTIFICATION =====================
    function showNotification(message, type = 'info') {
        const existing = document.querySelector('.fr-notification');
        if (existing) existing.remove();

        const notif = document.createElement('div');
        notif.className = `fr-notification ${type}`;
        notif.textContent = message;
        document.body.appendChild(notif);

        requestAnimationFrame(() => {
            notif.classList.add('show');
        });

        setTimeout(() => {
            notif.classList.remove('show');
            setTimeout(() => notif.remove(), 400);
        }, 3000);
    }

    // ===================== FORMAT NUMBER =====================
    function formatNumber(num) {
        return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    // ===================== UPDATE DISPLAY =====================
    function updateBalanceDisplay() {
        const el = document.querySelector('.fr-balance-amount');
        if (el) {
            el.textContent = formatNumber(fakeRobux);
        }
        // Also try to update Roblox navbar balance
        try {
            const navRobux = document.querySelector('#nav-robux-amount, .navbar-robux-amount, [class*="robux-amount"], .icon-robux-16x16');
            if (navRobux) {
                navRobux.textContent = formatNumber(fakeRobux);
            }
        } catch(e) {}
    }

    // ===================== FAKE BUY =====================
    function fakeBuy(amount, itemName) {
        return new Promise((resolve) => {
            if (fakeRobux < amount) {
                showNotification(`❌ Không đủ Robux! Cần ${formatNumber(amount)} R$ nhưng bạn chỉ có ${formatNumber(fakeRobux)} R$`, 'error');
                resolve(false);
                return;
            }

            // Hiệu ứng loading
            showNotification(`🛒 Đang xử lý giao dịch "${itemName}"...`, 'info');

            setTimeout(() => {
                fakeRobux -= amount;
                updateBalanceDisplay();
                // Cập nhật balance trên Roblox luôn nếu có thể
                try {
                    const els = document.querySelectorAll('[class*="robux"], [id*="robux"], [class*="currency"]');
                    els.forEach(el => {
                        if (el.textContent && el.textContent.includes(',')) {
                            el.textContent = formatNumber(fakeRobux);
                        }
                    });
                } catch(e) {}
                showNotification(`✅ Mua "${itemName}" thành công! -${formatNumber(amount)} R$, Số dư còn lại: ${formatNumber(fakeRobux)} R$`, 'success');
                resolve(true);
            }, 1500 + Math.random() * 1000);
        });
    }

    // ===================== BUILD UI =====================
    function buildUI() {
        const existing = document.getElementById('fakeRobuxUI');
        if (existing) existing.remove();

        const container = document.createElement('div');
        container.id = 'fakeRobuxUI';

        // ---- HEADER ----
        const header = document.createElement('div');
        header.className = 'fr-header fr-drag-handle';
        header.innerHTML = `
            <div class="fr-header-title">Fake Robux</div>
            <div class="fr-header-controls">
                <button class="fr-minimize-btn" id="frMinimizeBtn" title="Thu nhỏ">➖</button>
                <button class="fr-close-btn" id="frCloseBtn" title="Đóng">✕</button>
            </div>
        `;

        // ---- BODY ----
        const body = document.createElement('div');
        body.className = 'fr-body';
        body.innerHTML = `
            <div class="fr-balance-display">
                <div class="fr-balance-label">SỐ DƯ ROBUX ẢO</div>
                <div class="fr-balance-amount">0</div>
            </div>
            <div class="fr-input-group">
                <input type="number" class="fr-input" id="frRobuxInput" placeholder="Nhập số Robux..." min="0" value="100000">
                <button class="fr-btn" id="frConfirmBtn">✔ Xác nhận</button>
            </div>
            <div class="fr-buy-section">
                <div class="fr-buy-title">🛒 MUA SẮM ẢO (Robux ảo bị trừ)</div>
                <div class="fr-buy-grid">
                    <button class="fr-buy-btn" data-amount="25">Bloxy Cola <span class="fr-item-price">25 R$</span></button>
                    <button class="fr-buy-btn" data-amount="100">Speed coil <span class="fr-item-price">100 R$</span></button>
                    <button class="fr-buy-btn" data-amount="400">Superball <span class="fr-item-price">400 R$</span></button>
                    <button class="fr-buy-btn" data-amount="800">Dominus <span class="fr-item-price">800 R$</span></button>
                    <button class="fr-buy-btn" data-amount="2500">Head Slice <span class="fr-item-price">2,500 R$</span></button>
                    <button class="fr-buy-btn" data-amount="10000">Sparkle TF <span class="fr-item-price">10,000 R$</span></button>
                </div>
                <div style="margin-top: 8px; display: flex; gap: 6px;">
                    <button class="fr-btn fr-btn-danger" id="frResetBtn" style="flex:1; font-size:12px; padding:8px;">🔄 Reset</button>
                    <button class="fr-btn fr-btn-secondary" id="frAdd1mBtn" style="flex:1; font-size:12px; padding:8px;">+1,000,000</button>
                </div>
            </div>
        `;

        // ---- FOOTER ----
        const footer = document.createElement('div');
        footer.className = 'fr-footer';
        footer.innerHTML = `<div class="fr-credit">✨ <span>${CREDIT_TEXT}</span> ✨</div>`;

        container.appendChild(header);
        container.appendChild(body);
        container.appendChild(footer);
        document.body.appendChild(container);

        // ===================== EVENTS =====================

        // 1. Xác nhận nhập Robux
        document.getElementById('frConfirmBtn').addEventListener('click', () => {
            const input = document.getElementById('frRobuxInput');
            let val = parseInt(input.value);
            if (isNaN(val) || val < 0) val = 0;
            fakeRobux = val;
            updateBalanceDisplay();
            showNotification(`✅ Đã fake ${formatNumber(fakeRobux)} Robux thành công!`, 'success');
        });

        // 2. Enter key
        document.getElementById('frRobuxInput').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                document.getElementById('frConfirmBtn').click();
            }
        });

        // 3. Nút mua hàng ảo
        document.querySelectorAll('.fr-buy-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const amount = parseInt(this.dataset.amount);
                const itemName = this.childNodes[0].textContent.trim();
                this.disabled = true;
                await fakeBuy(amount, itemName);
                this.disabled = false;
            });
        });

        // 4. Reset
        document.getElementById('frResetBtn').addEventListener('click', () => {
            fakeRobux = 0;
            updateBalanceDisplay();
            document.getElementById('frRobuxInput').value = 0;
            showNotification('🔄 Đã reset Robux về 0', 'info');
        });

        // 5. +1M
        document.getElementById('frAdd1mBtn').addEventListener('click', () => {
            fakeRobux += 1000000;
            updateBalanceDisplay();
            document.getElementById('frRobuxInput').value = fakeRobux;
            showNotification(`💰 Đã thêm 1,000,000 R$! Tổng: ${formatNumber(fakeRobux)} R$`, 'success');
        });

        // 6. Minimize
        document.getElementById('frMinimizeBtn').addEventListener('click', () => {
            container.classList.toggle('minimized');
            const btn = document.getElementById('frMinimizeBtn');
            if (container.classList.contains('minimized')) {
                btn.textContent = '↗';
                btn.innerHTML = '';
                const arrow = document.createElement('span');
                arrow.className = 'fr-arrow-icon';
                arrow.textContent = '➡';
                btn.appendChild(arrow);
            } else {
                btn.textContent = '➖';
            }
        });

        // 7. Close
        document.getElementById('frCloseBtn').addEventListener('click', () => {
            container.style.transform = 'scale(0)';
            container.style.opacity = '0';
            setTimeout(() => {
                container.remove();
            }, 300);
        });

        // ===================== DRAG (di chuyển) =====================
        let isDragging = false;
        let dragOffsetX, dragOffsetY;

        header.addEventListener('mousedown', (e) => {
            if (e.target.closest('.fr-header-controls')) return;
            isDragging = true;
            const rect = container.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            container.style.cursor = 'grabbing';
            container.style.transition = 'none';
        });

        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            let x = e.clientX - dragOffsetX;
            let y = e.clientY - dragOffsetY;
            // Keep in viewport
            const w = container.offsetWidth;
            const h = container.offsetHeight;
            x = Math.max(0, Math.min(x, window.innerWidth - w));
            y = Math.max(0, Math.min(y, window.innerHeight - h));
            container.style.left = x + 'px';
            container.style.top = y + 'px';
        });

        document.addEventListener('mouseup', () => {
            if (isDragging) {
                isDragging = false;
                container.style.cursor = '';
                container.style.transition = '';
            }
        });

        // ===================== PERSIST ROBUX ON ROBLOX PAGE =====================
        // Interval để cập nhật liên tục balance trên Roblox
        setInterval(() => {
            try {
                const robuxElements = document.querySelectorAll('#nav-robux-amount, .navbar-robux-amount, [class*="robux-amount"], .icon-robux-16x16');
                robuxElements.forEach(el => {
                    if (el.textContent && el.textContent !== formatNumber(fakeRobux) && fakeRobux > 0) {
                        el.textContent = formatNumber(fakeRobux);
                    }
                });
            } catch(e) {}
        }, 500);

        // Initial update
        updateBalanceDisplay();
        if (fakeRobux > 0) {
            showNotification(`💰 Fake Robux: ${formatNumber(fakeRobux)} R$ đã sẵn sàng!`, 'info');
        }
    }

    // ===================== INIT =====================
    // Wait for DOM
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', buildUI);
    } else {
        buildUI();
    }

    // Retry if page changes (SPA)
    let retryCount = 0;
    const retryInterval = setInterval(() => {
        if (!document.getElementById('fakeRobuxUI') && retryCount < 20) {
            buildUI();
            retryCount++;
        } else {
            clearInterval(retryInterval);
        }
    }, 3000);

    console.log('%c🎮 Fake Robux Script Loaded!', 'color: #00d4ff; font-size: 16px; font-weight: bold;');
    console.log(`%c✨ ${CREDIT_TEXT}`, 'color: #ff00ea; font-size: 14px;`);

})();
