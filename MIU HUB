        }
        .fr-btn-success {
            background: linear-gradient(135deg, #00e676, #00c853);
        }
        .fr-btn-success:hover {
            box-shadow: 0 0 20px rgba(0,230,118,0.5);
        }
        .fr-btn-danger {
            background: linear-gradient(135deg, #ff1744, #d50000);
        }
        .fr-btn-danger:hover {
