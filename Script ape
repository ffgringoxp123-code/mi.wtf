-- ====== HÀM AUTO PARRY THỰC TẾ ======
local function startAutoParry()
    getgenv().AutoParryEnabled = true
    
    if getgenv().AutoParryThread then
        task.cancel(getgenv().AutoParryThread)
        getgenv().AutoParryThread = nil
    end
    
    getgenv().AutoParryThread = task.spawn(function()
        while getgenv().AutoParryEnabled do
            pcall(function()
                -- Kích hoạt Auto Parry thực tế
                local args = {
                    [1] = "ParryRequest"
                }
                game:GetService("ReplicatedStorage"):WaitForChild("Remotes", 5):FindFirstChild("Parry"):InvokeServer(unpack(args))
                
                -- Hoặc dùng phương pháp khác
                local lp = game:GetService("Players").LocalPlayer
                if lp and lp.Character and lp.Character:FindFirstChild("Humanoid") then
                    -- Kích hoạt parry
                    local ball = workspace:FindFirstChild("Ball") or workspace:FindFirstChildWhichIsA("Part")
                    if ball and lp.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (ball.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                        if dist < 50 then
                            -- Tự động parry khi bóng ở gần
                            fireclickdetector(game:GetService("Workspace"):FindFirstChild("ClickDetector") or Instance.new("ClickDetector"))
                        end
                    end
                end
            end)
            task.wait(0.05) -- Check mỗi 0.05s
        end
    end)
end

local function stopAutoParry()
    getgenv().AutoParryEnabled = false
    if getgenv().AutoParryThread then
        task.cancel(getgenv().AutoParryThread)
        getgenv().AutoParryThread = nil
    end
end

-- ====== HÀM SPAM PARRY LIÊN TỤC 0.001S ======
local function startSpam()
    getgenv().SpamIsRunning = true
    
    if getgenv().SpamThread then
        task.cancel(getgenv().SpamThread)
        getgenv().SpamThread = nil
    end
    
    getgenv().SpamThread = task.spawn(function()
        while getgenv().SpamIsRunning do
            pcall(function()
                -- Gửi Parry request liên tục
                local args = {
                    [1] = "ParryRequest"
                }
                local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes") or game:GetService("ReplicatedStorage"):FindFirstChild("Remote")
                if remote then
                    local parryRemote = remote:FindFirstChild("Parry") or remote:FindFirstChild("ParryEvent")
                    if parryRemote then
                        parryRemote:InvokeServer(unpack(args))
                    end
                end
                
                -- Cũng thử click detector
                pcall(function()
                    for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
                        if v:IsA("ClickDetector") then
                            fireclickdetector(v)
                        end
                    end
                end)
            end)
            task.wait(0.001) -- Spam mỗi 0.001s
        end
    end)
end

local function stopSpam()
    getgenv().SpamIsRunning = false
    if getgenv().SpamThread then
        task.cancel(getgenv().SpamThread)
        getgenv().SpamThread = nil
    end
end

