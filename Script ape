-- Hệ thống Auto Parry
MainSection:NewToggle("Auto Parry", "Automatically parries ball", function(state)
    pcall(function()
        local lp = game:GetService("Players").LocalPlayer

        if getgenv().DeathConnection then 
            getgenv().DeathConnection:Disconnect() 
            getgenv().DeathConnection = nil 
        end
        if getgenv().RespawnConnection then 
            getgenv().RespawnConnection:Disconnect() 
            getgenv().RespawnConnection = nil 
        end

        if state then
            startAutoParry()
            
            local function setup(char)
                local hum = char:WaitForChild("Humanoid", 10)
                if hum then
                    getgenv().DeathConnection = hum.Died:Connect(function()
                        stopAutoParry()
                    end)
                end
                task.wait(0.05)
            end

            if lp.Character then 
                setup(lp.Character)
            end
            
            getgenv().RespawnConnection = lp.CharacterAdded:Connect(function(char)
                setup(char)
                task.wait(0.5)
                if getgenv().AutoParryEnabled then
                    startAutoParry()
                end
            end)
        else
            stopAutoParry()
        end
    end)
end)

