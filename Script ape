--[[
    Apex Free - Blade Ball Script
    Sử dụng Kavo UI Library
]]

-- Load library Kavo UI
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Apex Free", "DarkTheme")

-- Tạo Tab chính
local MainTab = Window:NewTab("Main")
local MainSection = MainTab:NewSection("Auto Farm")

-- Biến trạng thái
local state = {
    AutoParry = false,
    SpamParry = false
}

-- Hàm spam parry
local function spamParryLoop()
    while state.SpamParry do
        pcall(function()
            local args = {
                [1] = "ParryRequest"
            }
            game:GetService("Players"):WaitForChild(game.Players.LocalPlayer.Name).Character:WaitForChild("RemoteEvent"):FireServer(unpack(args))
        end)
        task.wait(0.001)
    end
end

-- Hàm auto parry
local function autoParry()
    while state.AutoParry do
        pcall(function()
            local Players = game:GetService("Players")
            local LocalPlayer = Players.LocalPlayer
            local Character = LocalPlayer.Character
            if Character then
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer then
                        local targetChar = v.Character
                        if targetChar then
                            local ball = workspace:FindFirstChild("BladeBall") or workspace:FindFirstChild("Ball")
                            if ball then
                                local ballPos = ball.Position
                                local charPos = Character.PrimaryPart.Position
                                local distance = (ballPos - charPos).Magnitude
                                if distance < 15 then
                                    local args = {
                                        [1] = "ParryRequest"
                                    }
                                    Character:FindFirstChild("RemoteEvent"):FireServer(unpack(args))
                                end
                            end
                        end
                    end
                end
            end
        end)
        task.wait(0.1)
    end
end

-- Toggle Auto Parry
MainSection:NewToggle("Auto Parry", "Tự động đỡ bóng", function(value)
    state.AutoParry = value
    if value then
        coroutine.wrap(autoParry)()
    end
end)

-- Toggle Spam Parry
MainSection:NewToggle("Spam Parry", "Spam đỡ liên tục 0.001s", function(value)
    state.SpamParry = value
    if value then
        coroutine.wrap(spamParryLoop)()
    end
end)
