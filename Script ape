-- Hàm tạo nút chức năng
local function createFeatureButton(parent, name, text, color, callback)
    local btnFrame = Instance.new("Frame")
    btnFrame.Name = name .. "Frame"
    btnFrame.Size = UDim2.new(1, -10, 0, 35)
    btnFrame.Position = UDim2.new(0, 5, 0, 5 + (#parent:GetChildren() - 1) * 40)
    btnFrame.BackgroundColor3 = color or Color3.fromRGB(40, 40, 60)
    btnFrame.BackgroundTransparency = 0.2
    btnFrame.BorderSizePixel = 0
    btnFrame.Active = false
    btnFrame.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btnFrame
    
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Text = text
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.TextSize = 14
    btn.TextScaled = true
    btn.Parent = btnFrame
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(255, 255, 255)
    btnStroke.Transparency = 0.8
    btnStroke.Parent = btnFrame
    
    local btnActive = false
    
    btn.MouseButton1Click:Connect(function()
        btnActive = not btnActive
        btnFrame.BackgroundColor3 = btnActive and Color3.fromRGB(255, 50, 50) or color or Color3.fromRGB(40, 40, 60)
        btnFrame.BackgroundTransparency = btnActive and 0.1 or 0.2
        if callback then
            callback(btnActive)
        end
    end)
    
    return btnFrame
end

