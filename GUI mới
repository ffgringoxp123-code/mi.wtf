-- ====== CHỨC NĂNG THU NHỎ ======
local isMinimized = false
local originalSize = mainFrame.Size
local originalPos = mainFrame.Position

minimizeButton.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    
    if isMinimized then
        mainFrame:TweenSize(UDim2.new(0, 50, 0, 50), "Out", "Quad", 0.25, true)
        contentFrame.Visible = false
        titleFrame.Visible = false
        closeButton.Visible = false
        statusBar.Visible = false
        underline.Visible = false
        mainStroke.Thickness = 1.5
        minIcon.Text = "+"
        minimizeButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        minimizeButton.BackgroundTransparency = 0.15
        mainFrame.Position = UDim2.new(1, -58, 0, 12)
        mainCorner.CornerRadius = UDim.new(0, 8)
    else
        mainFrame:TweenSize(originalSize, "Out", "Quad", 0.25, true)
        contentFrame.Visible = true
        titleFrame.Visible = true
        closeButton.Visible = true
        statusBar.Visible = true
        underline.Visible = true
        mainStroke.Thickness = 2
        minIcon.Text = "−"
        minimizeButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        minimizeButton.BackgroundTransparency = 0.25
        mainFrame.Position = originalPos
        mainCorner.CornerRadius = UDim.new(0, 14)
    end
end)

-- ====== NÚT ĐÓNG ======
closeButton.MouseButton1Click:Connect(function()
    mainFrame:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Quad", 0.2, true)
    task.wait(0.2)
    screenGui:Destroy()
end)

-- ====== HIỆU ỨNG HOVER ======
minimizeButton.MouseEnter:Connect(function()
    if not isMinimized then
        minimizeButton.BackgroundTransparency = 0.1
    end
end)
minimizeButton.MouseLeave:Connect(function()
    if not isMinimized then
        minimizeButton.BackgroundTransparency = 0.25
    end
end)

closeButton.MouseEnter:Connect(function()
    closeButton.BackgroundColor3 = Color3.fromRGB(255, 40, 40)
    closeButton.BackgroundTransparency = 0.1
end)
closeButton.MouseLeave:Connect(function()
    closeButton.BackgroundColor3 = Color3.fromRGB(180, 25, 25)
    closeButton.BackgroundTransparency = 0.25
end)

-- ====== PULSE ANIMATION ======
task.spawn(function()
    while screenGui and screenGui.Parent do
        task.wait(0.8)
        if mainStroke and mainStroke.Parent then
            mainStroke.Transparency = mainStroke.Transparency == 0.15 and 0.35 or 0.15
        end
    end
end)

